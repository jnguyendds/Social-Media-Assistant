{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal.local/schemas/optimization-result.schema.json",
  "title": "Signal Optimization Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contentType", "platform", "format", "subject", "options"],
  "properties": {
    "contentType": { "enum": ["photo", "video"] },
    "platform": { "enum": ["instagram", "tiktok", "facebook", "youtube"] },
    "format": {
      "enum": ["feed-4x5", "square-1x1", "story-9x16", "reel-9x16", "tiktok-9x16", "short-9x16"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "cropFocus", "preserve"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "cropFocus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "preserve": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "summary", "risk", "platformFit", "output", "localEdits", "generativeEdits", "preservationRules"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1, "maxLength": 40 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 180 },
          "risk": { "enum": ["safe", "enhancement", "creative"] },
          "platformFit": { "type": "number", "minimum": 0, "maximum": 100 },
          "output": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "height", "aspectRatio"],
            "properties": {
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 },
              "aspectRatio": { "type": "string", "minLength": 3 }
            }
          },
          "localEdits": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "exposure": { "type": "number", "minimum": -1, "maximum": 1 },
              "contrast": { "type": "number", "minimum": -1, "maximum": 1 },
              "saturation": { "type": "number", "minimum": -1, "maximum": 1 },
              "temperature": { "type": "number", "minimum": -1, "maximum": 1 },
              "vignette": { "type": "number", "minimum": 0, "maximum": 1 },
              "cropMode": { "enum": ["contain", "cover", "subject-aware"] }
            }
          },
          "generativeEdits": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation", "target", "instruction"],
              "properties": {
                "operation": { "enum": ["remove", "reconstruct", "relight", "extend", "soften", "reduce-glare", "other"] },
                "target": { "type": "string", "minLength": 1 },
                "instruction": { "type": "string", "minLength": 1 }
              }
            }
          },
          "preservationRules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "chatGptEditPrompt": { "type": "string" }
        }
      }
    }
  }
}